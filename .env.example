# =============================================================================
# .env.example -- copy this to .env for LOCAL docker-compose use.
# NEVER commit a real .env file. This template contains no real values.
#
# On Render, you do NOT use this file directly -- you enter the same values
# into the Render Dashboard (the render.yaml Blueprint prompts for every
# variable marked sync: false). This file is the reference for what each one
# means and where its value comes from, whichever platform you're on.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE N8N CONFIG
# -----------------------------------------------------------------------------

# The single most important secret in this whole file. n8n uses this key to
# encrypt every credential (GitHub tokens, Gmail OAuth, API keys, etc.) stored
# in its database. Generate ONCE with:
#   openssl rand -hex 32
# Store it somewhere safe (password manager) outside this repo. If you ever
# lose it or change it after n8n has stored credentials, every stored
# credential becomes unreadable and must be re-entered. This value must stay
# IDENTICAL when you migrate from Render to Oracle Cloud later.
N8N_ENCRYPTION_KEY=

# Render terminates HTTPS at its edge and talks HTTP to your container.
# Setting this to https tells n8n to generate https:// links (editor URL,
# webhook URLs) even though it receives plain HTTP internally.
N8N_PROTOCOL=https

# The public hostname n8n will consider itself reachable at.
# Render: <your-service-name>.onrender.com (Render assigns this after your
#         first deploy -- you'll fill this in as a second step).
# Oracle Cloud (later): your VM's domain name or reserved public IP.
N8N_HOST=

# Port n8n listens on inside the container. Leave at 5678 (n8n's default)
# unless you have a specific reason to change it.
N8N_PORT=5678

# Render-specific: Render's platform-level PORT variable. This MUST be set
# to the same value as N8N_PORT above, or Render will not route traffic to
# your container correctly. Not needed outside Render (e.g. on Oracle Cloud).
PORT=5678

# Explicit webhook base URL. Belt-and-suspenders alongside N8N_HOST/PROTOCOL --
# set this whenever you're behind a proxy (Render always counts). Format:
# https://<your-host>/
WEBHOOK_URL=

# Number of reverse-proxy hops in front of n8n. Render = 1. A bare VM with no
# proxy in front (e.g. an early Oracle Cloud test) = 0.
N8N_PROXY_HOPS=1

# Requires HTTPS to actually work -- true is correct on Render (HTTPS at the
# edge) and correct once you put Oracle Cloud behind its own TLS proxy too.
N8N_SECURE_COOKIE=true

# IANA timezone name, e.g. America/New_York, Europe/London, Asia/Kolkata.
# Look yours up at https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Used by n8n's Schedule Trigger node so cron-style triggers fire at the time
# you actually mean.
GENERIC_TIMEZONE=
# Set to the exact same value as GENERIC_TIMEZONE. This one controls what the
# underlying OS/Node process considers "now" for logs and non-n8n-specific code.
TZ=

# Enables n8n's task-runner process (recommended by n8n's own current Docker
# install instructions; isolates code-node execution from the main process).
N8N_RUNNERS_ENABLED=true

# Hardens file permission checks on n8n's config/settings file.
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# -----------------------------------------------------------------------------
# DATABASE -- Supabase Postgres (recommended) or local Postgres (compose only)
# -----------------------------------------------------------------------------
# WHY SUPABASE INSTEAD OF SQLITE OR RENDER'S OWN POSTGRES:
# - n8n defaults to SQLite, a single file on local disk. Render's filesystem
#   is ephemeral outside of a paid persistent disk -- every redeploy or
#   restart would wipe your workflows and credentials.
# - Render's own free Postgres add-on is auto-deleted 30 days after creation.
#   Fine for a demo, wrong for anything you want to keep.
# - Supabase's Postgres persists independently of Render, and moving to
#   Oracle Cloud later means changing zero application code -- just point
#   the same DB_POSTGRESDB_* variables at the same Supabase project again.

DB_TYPE=postgresdb

# Supabase: Project Settings > Database > Connection info > Host
# (direct connection host looks like db.<project-ref>.supabase.co)
DB_POSTGRESDB_HOST=

DB_POSTGRESDB_PORT=5432

# Supabase: usually "postgres" unless you created a separate database
DB_POSTGRESDB_DATABASE=

# Supabase: usually "postgres", or a role you created specifically for n8n
# (recommended for production: create a dedicated least-privilege role
# rather than using the default postgres superuser)
DB_POSTGRESDB_USER=

# Supabase: Project Settings > Database > Database password
# (the password you set when the project was created, or reset it there)
DB_POSTGRESDB_PASSWORD=

DB_POSTGRESDB_SCHEMA=public

# Supabase requires SSL for external connections.
DB_POSTGRESDB_SSL_ENABLED=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=true
# NOTE: n8n's exact SSL variable naming has varied slightly across versions
# in community reports (DB_POSTGRESDB_SSL vs DB_POSTGRESDB_SSL_ENABLED). If
# the connection fails with an SSL-related error, check the Postgres section
# of https://docs.n8n.io for the exact variable name in your installed
# version before assuming the credentials themselves are wrong.

# -----------------------------------------------------------------------------
# EXECUTION DATA HYGIENE (recommended, not strictly required)
# -----------------------------------------------------------------------------
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
N8N_LOG_LEVEL=info

# =============================================================================
# FUTURE INTEGRATION CREDENTIALS -- READ THIS SECTION CAREFULLY
# =============================================================================
# None of the services below (GitHub, Telegram, Gmail, Google Drive, RSS,
# Supabase-as-a-workflow-node, AI providers) need a container environment
# variable at all. n8n stores per-service credentials encrypted in its own
# database (using N8N_ENCRYPTION_KEY above), entered through the editor UI at
# Credentials > Add Credential -- NOT through this .env file.
#
# This section exists purely as your reference for WHERE to go get each
# value when you sit down to configure that credential in the n8n UI.
#
# GitHub
#   -> github.com/settings/tokens (fine-grained PAT, scoped to the specific
#      repo(s) n8n needs) OR github.com/settings/developers to register an
#      OAuth App if you prefer the OAuth2 credential type instead of a PAT.
#
# Telegram
#   -> Message @BotFather on Telegram, /newbot, copy the bot token it gives you.
#
# Gmail / Google Drive
#   -> console.cloud.google.com: create a project, enable the Gmail API
#      and/or Google Drive API, create an OAuth 2.0 Client ID (type: Web
#      application), add https://<your-n8n-host>/rest/oauth2-credential/callback
#      as an authorized redirect URI. n8n's credential screen shows you this
#      exact callback URL to copy.
#
# RSS
#   -> No credential needed at all -- n8n's RSS Feed Trigger node just needs
#      the public feed URL.
#
# Supabase (as a workflow data source/target, separate from using it as n8n's
# own database above)
#   -> supabase.com project > Project Settings > API: Project URL and the
#      service_role or anon key, depending on what the workflow needs to do.
#
# AI providers (OpenAI, Anthropic, etc.)
#   -> platform.openai.com/api-keys, console.anthropic.com/settings/keys, or
#      the equivalent console for whichever provider you use.
# =============================================================================
